{
  "name": "StreakWar",
  "version": "1.0.0",
  "description": "Dark-mode fitness challenge app. Competitive, motivating, energetic. Orange primary on deep navy-black background.",

  "color": {
    "background": {
      "base":   { "value": "#0C1117", "description": "Screen background" },
      "card":   { "value": "#151C24", "description": "Card / surface" },
      "input":  { "value": "#1A2330", "description": "Text input fill" },
      "overlay":{ "value": "rgba(0,0,0,0.6)", "description": "Modal scrim" }
    },
    "border": {
      "default": { "value": "rgba(255,255,255,0.07)", "description": "Subtle card border" },
      "focus":   { "value": "rgba(249,115,22,0.35)",  "description": "Active / selected border" }
    },
    "text": {
      "primary": { "value": "#EEF4F8", "description": "Body copy, headings" },
      "muted":   { "value": "#637C8F", "description": "Secondary labels, timestamps — WCAG AA on bg/card" },
      "inverse": { "value": "#0C1117", "description": "Text on primary-coloured buttons" }
    },
    "brand": {
      "primary":       { "value": "#F97316", "description": "Orange — actions, streaks, CTAs" },
      "primarySubtle": { "value": "rgba(249,115,22,0.12)", "description": "Primary tinted surface" },
      "green":         { "value": "#22C55E", "description": "Success, positive delta, active status" },
      "greenSubtle":   { "value": "rgba(34,197,94,0.15)",  "description": "Success tinted surface" },
      "gold":          { "value": "#FBBF24", "description": "Gold league, #1 rank accents" },
      "silver":        { "value": "#94A3B8", "description": "Silver league, #2 rank accents" },
      "bronze":        { "value": "#CD7F32", "description": "#3 rank accents" },
      "purple":        { "value": "#7C3AED", "description": "Diamond league, Pro badge" },
      "red":           { "value": "#EF4444", "description": "Negative delta, error states" }
    }
  },

  "typography": {
    "fontFamily": {
      "default": { "value": "System", "description": "Platform system font (SF Pro on iOS, Roboto on Android)" }
    },
    "scale": {
      "streakHero":     { "size": 52, "weight": "900", "lineHeight": 56, "letterSpacing": -1, "description": "Streak day count — the number on the hero card" },
      "statValue":      { "size": 30, "weight": "900", "description": "Weekly recap stat numbers" },
      "weeklyHeadline": { "size": 26, "weight": "900", "description": "Personalised weekly recap headline" },
      "screenTitle":    { "size": 24, "weight": "800", "description": "Screen-level headings" },
      "cardTitle":      { "size": 20, "weight": "800", "description": "Card headings, challenge names" },
      "rankHero":       { "size": 22, "weight": "900", "description": "Rank number inside challenge cards" },
      "bodyHeader":     { "size": 17, "weight": "700", "description": "Section headers, button labels" },
      "body":           { "size": 14, "weight": "600", "description": "Primary body text" },
      "caption":        { "size": 12, "weight": "600", "description": "Metadata, timestamps, labels" },
      "sectionLabel":   { "size": 10, "weight": "700", "letterSpacing": 1.5, "description": "All-caps section labels" }
    }
  },

  "radius": {
    "hero":    { "value": 18, "description": "Streak hero card, modal sheets" },
    "card":    { "value": 16, "description": "Standard list cards" },
    "cardSm":  { "value": 14, "description": "Compact cards, bottom sheets" },
    "chip":    { "value": 12, "description": "Chips, tags, small badges" },
    "sm":      { "value": 10, "description": "Input fields, small elements" },
    "full":    { "value": 9999, "description": "Pills, avatar rings" }
  },

  "spacing": {
    "screenH": { "value": 20, "description": "Horizontal screen padding" },
    "list":    { "value": 16, "description": "List item padding" },
    "cardGap": { "value": 12, "description": "Gap between items inside a card" },
    "sectionGap": { "value": 24, "description": "Gap between sections" }
  },

  "shadow": {
    "card": {
      "color": "#000",
      "opacity": 0.3,
      "offset": { "width": 0, "height": 4 },
      "radius": 12,
      "description": "Elevation for cards floating over background"
    }
  },

  "motion": {
    "springReaction": {
      "type": "spring",
      "tension": 200,
      "friction": 7,
      "description": "Bounce spring used for emoji reaction buttons"
    },
    "springSuccess": {
      "type": "spring",
      "tension": 120,
      "friction": 8,
      "description": "Success overlay scale-in animation"
    },
    "fadeOut": {
      "type": "timing",
      "duration": 300,
      "description": "Success overlay fade out before dismiss"
    }
  },

  "component": {
    "touchTarget": { "minimum": 44, "description": "Minimum tappable area (iOS HIG + Android Material)" },
    "avatar": {
      "sizes": { "sm": 32, "md": 40, "lg": 48 },
      "border": { "width": 2, "color": "rgba(255,255,255,0.15)" }
    },
    "progressBar": {
      "height": 5,
      "backgroundColor": "rgba(255,255,255,0.08)",
      "fillColor": "#F97316",
      "borderRadius": 3
    },
    "button": {
      "primary": {
        "background": "#F97316",
        "text": "#0C1117",
        "paddingVertical": 14,
        "paddingHorizontal": 24,
        "borderRadius": 14,
        "fontSize": 17,
        "fontWeight": "700"
      },
      "secondary": {
        "background": "rgba(249,115,22,0.12)",
        "text": "#F97316",
        "borderWidth": 1,
        "borderColor": "rgba(249,115,22,0.3)",
        "paddingVertical": 12,
        "paddingHorizontal": 20,
        "borderRadius": 12,
        "fontSize": 15,
        "fontWeight": "600"
      },
      "ghost": {
        "background": "transparent",
        "text": "#637C8F",
        "paddingVertical": 10,
        "paddingHorizontal": 16,
        "borderRadius": 10,
        "fontSize": 14,
        "fontWeight": "600"
      }
    },
    "badge": {
      "rank": {
        "background": "rgba(249,115,22,0.15)",
        "borderColor": "rgba(249,115,22,0.3)",
        "borderWidth": 1,
        "borderRadius": 10,
        "paddingVertical": 4,
        "paddingHorizontal": 10,
        "fontSize": 12,
        "fontWeight": "700",
        "color": "#F97316"
      },
      "status": {
        "active":    { "background": "rgba(34,197,94,0.15)",  "color": "#22C55E" },
        "upcoming":  { "background": "rgba(99,124,143,0.15)", "color": "#637C8F" },
        "completed": { "background": "rgba(251,191,36,0.15)", "color": "#FBBF24" }
      }
    }
  }
}
