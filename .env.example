# .env.example – StreakWar environment variables
# Copy this to .env and fill in your values

# ── Supabase ────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# ── Push Notifications (Expo) ──────────────────────────────
EXPO_PUBLIC_PROJECT_ID=YOUR_EXPO_PROJECT_ID

# ── Strava OAuth ────────────────────────────────────────────
# https://www.strava.com/settings/api
STRAVA_CLIENT_ID=YOUR_STRAVA_CLIENT_ID
STRAVA_CLIENT_SECRET=YOUR_STRAVA_CLIENT_SECRET
# Random string used to verify Strava webhook subscription
STRAVA_VERIFY_TOKEN=streakwar_strava_verify

# ── Garmin Health API ───────────────────────────────────────
# https://developer.garmin.com/gc-developer-program/
GARMIN_CONSUMER_KEY=YOUR_GARMIN_CONSUMER_KEY
GARMIN_CONSUMER_SECRET=YOUR_GARMIN_CONSUMER_SECRET

# ── Fitbit OAuth ────────────────────────────────────────────
# https://dev.fitbit.com/apps/new
FITBIT_CLIENT_ID=YOUR_FITBIT_CLIENT_ID
FITBIT_CLIENT_SECRET=YOUR_FITBIT_CLIENT_SECRET
# Verification code shown in Fitbit app settings
FITBIT_VERIFY_CODE=YOUR_FITBIT_VERIFY_CODE

# ── Supabase Edge Functions (set these in Supabase Dashboard → Settings → Secrets) ──
# SUPABASE_SERVICE_ROLE_KEY is automatically available inside Edge Functions
