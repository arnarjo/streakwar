{
  "expo": {
    "name": "StreakWar",
    "slug": "streakwar",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0E14",
    "splash": {
      "backgroundColor": "#0A0E14",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0E14"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "react-native-health-connect"
    ]
  }
}
